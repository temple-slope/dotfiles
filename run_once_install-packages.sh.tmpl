#!/bin/bash

set -euo pipefail

{{ if .machine.installBrewBundle -}}
echo "🔍 実行環境: {{ .chezmoi.hostname }}"

# Homebrewがなければインストール
if ! command -v brew >/dev/null 2>&1; then
  echo "🍺 Homebrew が見つかりません。インストールします..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# M1/M2 Mac対応のbrewパス反映
eval "$(/opt/homebrew/bin/brew shellenv)"

# Brewfileを適用
echo "Brewfileを適用中..."
brew bundle --file="{{ joinPath .chezmoi.sourceDir "Brewfile" }}"
{{ else -}}
echo "⏭ パッケージインストールはスキップされました（.chezmoi.yaml.tmpl の installBrewBundle = false）。"
{{ end -}}
