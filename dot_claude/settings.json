{
  "cleanupPeriodDays": 14,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(tree:*)",
      "Bash(tmux:*)",
      "Bash(make:*)",
      "Bash(touch:*)",
      "Bash(diff:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -v)",
      "Bash(git rev-parse:*)",
      "Bash(git remote -v)",
      "Bash(chezmoi:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(npm list:*)",
      "Bash(node -v)",
      "Bash(npm -v)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:qiita.com)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(~/.ssh/id_*)", "Read(~/.aws/credentials)"]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-stop.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-permission.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-idle.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/export-session.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "n8n-mcp-skills@n8n-mcp-skills": true,
    "example-skills@anthropic-agent-skills": true
  },
  "sandbox": {
    "allowUnixSockets": ["~/.ssh/control-*"]
  },
  "alwaysThinkingEnabled": true,
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 2
  }
}
