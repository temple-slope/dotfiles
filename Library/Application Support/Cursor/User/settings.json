{
  // =========================================
  // 💻 Terminal configuration for macOS
  // =========================================
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.profiles.osx": {
    "tmux": {
      "path": "tmux",
      "args": ["new-session", "-A", "-s", "$(workspaceFolderBasename)"]
    }
  },

  // =========================================
  // 🖋 Editor Appearance & Behavior
  // =========================================
  "editor.fontSize": 14,
  "editor.fontFamily": "Cica, Consolas, 'Courier New', monospace", // 日本語対応フォント
  "editor.tabSize": 2,
  "editor.insertSpaces": true, // tabをスペースとして扱う
  "editor.wordWrap": "on", // 長い行を折り返す
  "editor.renderWhitespace": "boundary", // 空白を表示
  "editor.cursorBlinking": "smooth", // カーソル点滅スタイル
  "editor.cursorSmoothCaretAnimation": "on", // カーソルアニメーション
  "editor.accessibilitySupport": "off",
  "files.exclude": {
    "**/.git": false
  },
  "explorer.excludeGitIgnore": false,
  "git.autofetch": true,

  // =========================================
  // 💾 File Handling
  // =========================================
  "files.autoSave": "onFocusChange", // フォーカス外れたら保存
  "files.insertFinalNewline": true,

  // =========================================
  // 🎨 Workbench UI
  // =========================================
  "workbench.colorTheme": "GitHub Dark",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.activityBar.orientation": "vertical",

  // =========================================
  // 📁 Explorer
  // =========================================
  "explorer.confirmDelete": false, // 削除確認を省略
  "explorer.confirmDragAndDrop": false, // ドラッグ＆ドロップ確認を省略

  // =========================================
  // 💻 Terminal
  // =========================================
  "terminal.integrated.fontFamily": "MesloLGS NF", // powerline アイコン対応フォント

  // =========================================
  // ⚙ Extensions
  // =========================================
  "extensions.autoUpdate": true,

  // =========================================
  // 🧹 Prettier
  // =========================================
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "prettier.requireConfig": true, // .prettierrc がないと整形しないようにする

  // =========================================
  // 🧠 VSCodeVim Settings
  // =========================================
  "vim.useSystemClipboard": true, // OSのクリップボードと連携

  // Normal モード キーバインド
  "vim.normalModeKeyBindingsNonRecursive": [
    { "before": ["H"], "after": ["0"] }, // 行頭へ移動
    { "before": ["L"], "after": ["$"] } // 行末へ移動
  ],

  // Insert モード キーバインド
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],

  // Visual モード（未使用だが構文維持）
  "vim.visualModeKeyBindingsNonRecursive": [],

  // =========================================
  // 🧠 Extensions
  // =========================================
  "extensions.ignoreRecommendations": true,

  // =========================================
  // 📄 Markdown PDF
  // =========================================
  "markdown-pdf.margin.top": "10mm",
  "markdown-pdf.margin.bottom": "10mm",
  "markdown-pdf.margin.right": "10mm",
  "markdown-pdf.margin.left": "10mm",
  "markdown-pdf.headerTemplate": "<div></div>",
  "markdown-pdf.footerTemplate": "<div></div>",
  "markdown-pdf.displayHeaderFooter": false,
  "markdown-pdf.printBackground": true
}
