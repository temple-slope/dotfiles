# =============================================================================
# .chezmoiignore - chezmoi による管理対象外ファイル
# =============================================================================

# -----------------------------------------------------------------------------
# 機密情報・認証情報
# -----------------------------------------------------------------------------

# 汎用パターン（1password スキルを除外）
!.claude/skills/1password
!.claude/skills/1password/**
**/*auth*
**/*token*
**/*secret*
**/*credential*
**/*password*

# Docker - 自動生成トークン
.docker/.token_seed

# Claude Code - 認証情報
.claude/.credentials.json

# GitHub CLI - ホスト認証情報
dot_config/gh/hosts.yml

# AWS - 設定ファイル
.aws/config

# -----------------------------------------------------------------------------
# 環境・ローカル固有設定
# -----------------------------------------------------------------------------

# 環境変数ファイル
**/.env
**/.env.*

# -----------------------------------------------------------------------------
# キャッシュ・一時ファイル
# -----------------------------------------------------------------------------

**/*cache*
**/tmp/

# Neovim - プラグインロックファイル（環境依存）
dot_config/nvim/lazy-lock.json
dot_config/nvim/lazyvim.json

# -----------------------------------------------------------------------------
# Codex CLI - ランタイムデータ・ベンダー配布物（CLI が自動更新する領域）
# config.toml は管理対象
# -----------------------------------------------------------------------------

.codex/auth.json
.codex/history.jsonl
.codex/installation_id
.codex/models_cache.json
.codex/version.json
.codex/logs_*
.codex/state_*
.codex/log/
.codex/sessions/
.codex/plugins/
.codex/skills/
.codex/rules/
.codex/.tmp/

# -----------------------------------------------------------------------------
# Claude Code - chezmoi 管理外（superpowers プラグインで管理）
# -----------------------------------------------------------------------------

.claude
CLAUDE.md

.github
.git

# -----------------------------------------------------------------------------
# プロジェクト固有（chezmoi リポジトリ自体）
# -----------------------------------------------------------------------------

# TypeScript コンパイル設定（dotfiles 管理対象外）
tsconfig.json
